{
  "name": "neonlink-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "NeonLink Desktop (Chat, Kalender, Arbeitsplan)",
  "author": "NeonLink",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server:dev": "npm run dev --prefix server",
    "server:build": "npm run build --prefix server",
    "build:desktop": "npm run server:build && cross-env VITE_EMBED_DESKTOP=true npm run build",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run server:dev\" \"wait-on http-get://127.0.0.1:4000/health http://127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://127.0.0.1:5173 electron .\"",
    "electron:pack": "npm run build:desktop && npm prune --omit=dev --prefix server && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "electron:dist": "npm run build:desktop && npm prune --omit=dev --prefix server && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "framer-motion": "^12.10.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.510.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.neonlink.desktop",
    "productName": "NeonLink",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "electron/build"
    },
    "files": ["electron/main.cjs", "electron/build/icon.png", "package.json"],
    "extraResources": [
      { "from": "dist", "to": "app-dist" },
      { "from": "server/dist", "to": "app-server/dist" },
      { "from": "server/package.json", "to": "app-server/package.json" },
      { "from": "server/node_modules", "to": "app-server/node_modules" }
    ],
    "win": {
      "target": ["nsis"],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
